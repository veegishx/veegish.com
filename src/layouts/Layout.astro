---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Theme detection - MUST be first to prevent flash -->
    <script is:inline>
      (function () {
        const m = document.cookie.match(/(?:^|; )theme=(light|dark)/);
        const html = document.documentElement;
        const s = (t) => {
          html.classList.toggle("dark", t === "dark");
          html.style.backgroundColor = t === "dark" ? "#18181b" : "#fff";
          html.style.colorScheme = t === "dark" ? "dark" : "light";
        };
        if (m) return s(m[1]);
        try {
          const stored = localStorage.getItem("theme");
          if (stored) return s(stored);
        } catch {}
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) return s("dark");
        s("light");
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=ibm-plex-mono:400,400i,500,500i,600,600i,700,700i"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="zag-bg zag-text font-mono">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
