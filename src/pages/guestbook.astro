---
import Layout from "../layouts/Layout.astro";
import Section from "../components/common/Section.astro";
import { getGuestbookDb } from "../lib/guestbook/db";

export const prerender = false;

function toUtcDateString(ms: number): string {
  const d = new Date(ms);
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, "0");
  const day = String(d.getUTCDate()).padStart(2, "0");
  return `${y}-${m}-${day}`;
}

const signed = Astro.url.searchParams.get("signed") === "1";
const error = Astro.url.searchParams.get("error") ?? "";
const db = getGuestbookDb();
const res = await db.execute({
  sql: "SELECT id, name, message, website, created_at FROM guestbook_messages ORDER BY created_at DESC LIMIT 50",
  args: [],
});
const messages = res.rows.map((r) => ({
  id: String(r.id),
  name: String(r.name),
  message: String(r.message),
  website: r.website ? String(r.website) : undefined,
  createdAt: Number(r.created_at),
}));
---

<Layout>
  <Fragment slot="head">
    <title>Guestbook</title>
    <meta name="description" content="Leave a message in the guestbook." />
  </Fragment>

  <Section class="my-16">
    <header class="mb-8" id="sprite-hover">
      <div class="flex flex-col md:flex-row items-center gap-4 pt-8 pb-8">
        <span class="guestbook-sprite inline-block flex-none" aria-hidden="true"
        ></span>
        <div
          class="w-full flex flex-col items-center md:items-start md:flex-row md:justify-between gap-2"
        >
          <h1
            class="font-display text-2xl sm:text-3xl tracking-tight flex flex-wrap items-center gap-2 relative"
          >
            <span class="gb-hover-text">
              Sign
              <span class="gb-strike-text">the guestbook</span><span
                class="gb-pact-text">a pact with the devil >:)</span
              >
            </span>
            GUESTBOOK
          </h1>
        </div>
      </div>
      <p class="zag-muted mt-0 md:mt-0 text-base leading-relaxed">
        Like it's 1999. Leave a note, a link, a memory.
      </p>
    </header>

    {
      signed && (
        <div class="gb-banner mb-6 p-4">
          <p class="font-mono text-sm">Entry logged. Thanks for signing.</p>
        </div>
      )
    }

    {
      error && (
        <div class="gb-banner gb-banner-error mb-6 p-4">
          <p class="font-mono text-sm">{error}</p>
        </div>
      )
    }

    <div class="gb-panel p-4 sm:p-6">
      <div class="flex items-baseline justify-between gap-4">
        <p class="font-display text-lg">SIGN THE BOOK</p>
        <p class="gb-ascii font-mono text-xs sm:text-sm">
          [ & REST WELL TRAVELLER. ]
        </p>
      </div>

      <form method="post" action="/api/guestbook" class="mt-6 grid gap-4">
        <input
          class="gb-hp"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          name="gb_fax"
        />

        <label class="grid gap-2">
          <span class="font-mono text-sm">Name (required)</span>
          <input
            name="name"
            required
            maxlength="60"
            class="gb-input font-mono"
            placeholder="Your handle"
          />
        </label>

        <label class="grid gap-2">
          <span class="font-mono text-sm">Message (required)</span>
          <textarea
            name="message"
            required
            maxlength="1000"
            rows={5}
            class="gb-input font-mono"
            placeholder="Say hello..."></textarea>
        </label>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2">
            <span class="font-mono text-sm">Website (optional)</span>
            <input
              name="website"
              maxlength="200"
              class="gb-input font-mono"
              placeholder="https://example.com"
            />
          </label>

          <label class="grid gap-2 relative">
            <span class="font-mono text-sm"
              >Email (optional, not displayed)</span
            >
            <input
              name="email"
              type="email"
              maxlength="200"
              class="gb-input font-mono"
              placeholder="you@example.com"
            />
            <span class="absolute text-green-500 -bottom-4 font-mono text-[9px]"
              >Stored as encrypted string for your peace of mind</span
            >
          </label>
        </div>

        <div
          class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mt-2"
        >
          <p class="gb-ascii font-mono text-xs sm:text-sm">
            ------------------------------------------------------------
          </p>
          <button type="submit" class="gb-button font-display text-sm">
            SUBMIT
          </button>
        </div>
      </form>
    </div>

    <div class="mt-10" id="gb-entries" data-density="guestbook">
      <div
        class="flex flex-col gap-3 sm:flex-row items-baseline md:items-center justify-between sm:gap-4 mb-4"
      >
        <div class="w-full flex items-baseline justify-between gap-4 relative">
          <p class="font-display text-lg leading-0">ENTRIES</p>
          <p class="gb-ascii font-mono text-xs sm:text-sm leading-0">
            [ SANTA WAS HERE ]
          </p>
          <span class="text-[10px] absolute -bottom-6 right-0">allegedly</span>
        </div>

        <div class="gb-toggle-row" aria-label="Entries density">
          <button
            type="button"
            class="gb-toggle"
            data-density-btn="guestbook"
            aria-pressed="true"
          >
            GUESTBOOK
          </button>
          <button
            type="button"
            class="gb-toggle"
            data-density-btn="compact"
            aria-pressed="false"
          >
            COMPACT
          </button>
        </div>
      </div>

      {
        messages.length === 0 ? (
          <div class="gb-panel p-6">
            <p class="font-mono text-sm">No entries yet. You can be first.</p>
          </div>
        ) : (
          <ol class="gb-list grid gap-4">
            {messages.map((m) => (
              <li class="gb-entry p-4 sm:p-5">
                <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
                  <p class="font-mono text-sm">
                    <span class="gb-name">{m.name}</span>
                    {m.website && (
                      <>
                        <span class="gb-ascii"> :: </span>
                        <a
                          class="gb-link gb-url"
                          href={m.website}
                          rel="nofollow noopener noreferrer"
                          target="_blank"
                        >
                          {m.website.replace(/^https?:\/\//i, "")}
                        </a>
                      </>
                    )}
                  </p>
                  <p class="font-mono text-xs zag-muted">
                    {toUtcDateString(m.createdAt)}
                  </p>
                </div>
                <p class="gb-ascii gb-ascii-divider font-mono text-xs sm:text-sm mt-2">
                  ============================================================
                </p>
                <p class="font-mono text-sm leading-relaxed mt-3 gb-message">
                  {m.message}
                </p>
              </li>
            ))}
          </ol>
        )
      }
    </div>
  </Section>

  </script>

  <style>
    :root {
      --guestbook-size: 64px;
      --guestbook-frames: 52;
    }

    @media (min-width: 640px) {
      :root {
        --guestbook-size: 80px;
      }
    }

    @media (min-width: 768px) {
      :root {
        --guestbook-size: 96px;
      }
    }

    .guestbook-sprite {
      width: var(--guestbook-size);
      height: var(--guestbook-size);
      background-image: url("/guestbookspritesheet.png");
      background-repeat: no-repeat;
      background-size: calc(var(--guestbook-size) * var(--guestbook-frames))
        var(--guestbook-size);
      background-position: 0 0;
      image-rendering: pixelated;
    }

    #sprite-hover:hover .guestbook-sprite {
      animation: guestbook-walk 3s steps(var(--guestbook-frames)) infinite;
    }

    @keyframes guestbook-walk {
      from {
        background-position: 0 0;
      }
      to {
        background-position: calc(
            -1 * var(--guestbook-size) * var(--guestbook-frames)
          )
          0;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #sprite-hover:hover .guestbook-sprite {
        animation: none;
      }
      #sprite-hover:hover .gb-hover-text {
        animation: none;
        opacity: 1;
        transform: translateY(-50%);
      }
      #sprite-hover:hover .gb-strike-text {
        animation: none;
        text-decoration: none;
      }
      #sprite-hover:hover .gb-pact-text {
        animation: none;
        opacity: 1;
      }
    }

    .gb-hover-text {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-100%);
      opacity: 0;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      letter-spacing: 0.05em;
      color: var(--color-zag-accent-dark);
      pointer-events: none;
      white-space: nowrap;
      z-index: 0;
    }

    :where(.dark, .dark *) .gb-hover-text {
      color: var(--color-zag-accent-light);
    }

    #sprite-hover:hover .gb-hover-text {
      animation: gb-hover-slide 0.8s ease-out forwards;
    }

    #sprite-hover:hover .gb-strike-text {
      animation: gb-hover-strike 1.5s ease-in-out 1s forwards;
    }

    #sprite-hover:hover .gb-pact-text {
      animation: gb-pact-show 0.5s ease-in-out 1.5s forwards;
    }

    .gb-hover-text {
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-100%);
      opacity: 0;
      font-family: var(--font-mono);
      font-size: 0.875rem;
      letter-spacing: 0.05em;
      color: var(--color-zag-accent-dark);
      pointer-events: none;
      white-space: nowrap;
      z-index: 0;
    }

    .gb-pact-text {
      color: #ef4444;
      opacity: 0;
      margin-left: 0.25rem;
      display: inline-block;
    }

    :where(.dark, .dark *) .gb-hover-text {
      color: var(--color-zag-accent-light);
    }

    .gb-strike-text {
      display: inline-block;
      text-decoration: none;
    }

    #sprite-hover:hover .gb-strike-text {
      animation: gb-hover-strike 1.5s ease-in-out 1s forwards;
    }

    .gb-strike-text {
      display: inline-block;
      text-decoration: none;
    }

    @keyframes gb-hover-slide {
      0% {
        opacity: 0;
        transform: translateY(-20%);
      }
      100% {
        opacity: 1;
        transform: translateY(120%);
      }
    }

    @keyframes gb-hover-strike {
      0% {
        text-decoration: none;
      }
      100% {
        text-decoration: line-through;
        text-decoration-thickness: 2px;
        text-decoration-color: currentColor;
      }
    }

    @keyframes gb-pact-show {
      0% {
        opacity: 0;
      }
      100% {
        opacity: 1;
      }
    }
  </style>

  <script is:inline>
    (() => {
      const root = document.getElementById("gb-entries");
      if (!root) return;

      const buttons = Array.from(root.querySelectorAll("[data-density-btn]"));
      const normalize = (v) => (v === "compact" ? "compact" : "guestbook");

      function safeGet(key) {
        try {
          return localStorage.getItem(key);
        } catch {
          return null;
        }
      }

      function safeSet(key, value) {
        try {
          localStorage.setItem(key, value);
        } catch {
          // ignore
        }
      }

      function apply(next) {
        const density = normalize(next);
        root.dataset.density = density;
        for (const btn of buttons) {
          const val = btn.getAttribute("data-density-btn");
          const active = val === density;
          btn.setAttribute("aria-pressed", active ? "true" : "false");
          btn.classList.toggle("gb-toggle-active", active);
        }
      }

      const saved = safeGet("guestbookDensity");
      apply(saved);

      for (const btn of buttons) {
        btn.addEventListener("click", () => {
          const next = btn.getAttribute("data-density-btn");
          if (!next) return;
          apply(next);
          safeSet("guestbookDensity", normalize(next));
        });
      }
    })();
  </script>

  <style>
    .gb-panel {
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-dark);
    }
    :where(.dark, .dark *) .gb-panel {
      border-color: var(--color-zag-light);
    }
    .gb-entry {
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-dark-muted);
      position: relative;
      min-width: 0;
    }
    :where(.dark, .dark *) .gb-entry {
      border-color: var(--color-zag-light-muted);
    }
    .gb-entry::before {
      content: "";
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity var(--zag-transition-duration)
        var(--zag-transition-timing-function);
      background:
        linear-gradient(
            90deg,
            transparent 0 31px,
            color-mix(in oklab, currentColor 6%, transparent) 31px 32px
          )
          0 0 / 32px 32px,
        linear-gradient(
            transparent 0 31px,
            color-mix(in oklab, currentColor 6%, transparent) 31px 32px
          )
          0 0 / 32px 32px;
      pointer-events: none;
    }
    .gb-entry:hover::before {
      opacity: 1;
    }

    .gb-toggle-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
    .gb-toggle {
      padding: 0.65rem 0.75rem;
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-dark);
      background: transparent;
      cursor: pointer;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      user-select: none;
      text-transform: uppercase;
    }
    :where(.dark, .dark *) .gb-toggle {
      border-color: var(--color-zag-light);
    }
    .gb-toggle-active {
      background: var(--color-zag-dark);
      color: var(--color-zag-light);
    }
    :where(.dark, .dark *) .gb-toggle-active {
      background: var(--color-zag-light);
      color: var(--color-zag-dark);
    }

    #gb-entries[data-density="compact"] .gb-list {
      gap: 0.5rem;
    }
    #gb-entries[data-density="compact"] .gb-entry {
      padding: 0.75rem;
    }
    #gb-entries[data-density="compact"] .gb-message {
      margin-top: 0.5rem;
      line-height: 1.35;
    }
    #gb-entries[data-density="compact"] .gb-ascii-divider {
      display: none;
    }

    .gb-url {
      overflow-wrap: anywhere;
      word-break: break-word;
    }
    .gb-input {
      width: 100%;
      padding: 0.75rem 0.875rem;
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-dark);
      background-color: transparent;
      outline: none;
    }
    :where(.dark, .dark *) .gb-input {
      border-color: var(--color-zag-light);
    }
    .gb-input:focus {
      border-color: var(--color-zag-accent-dark);
      box-shadow: 0 0 0 2px
        color-mix(in oklab, var(--color-zag-accent-dark) 30%, transparent);
    }
    :where(.dark, .dark *) .gb-input:focus {
      border-color: var(--color-zag-accent-light);
      box-shadow: 0 0 0 2px
        color-mix(in oklab, var(--color-zag-accent-light) 30%, transparent);
    }
    .gb-button {
      padding: 0.75rem 1rem;
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-dark);
      background: var(--color-zag-light);
      cursor: pointer;
    }
    :where(.dark, .dark *) .gb-button {
      border-color: var(--color-zag-light);
      background: var(--color-zag-dark);
    }
    .gb-button:hover {
      transform: translateY(-1px);
    }
    .gb-ascii {
      opacity: 0.8;
      letter-spacing: 0.04em;
      user-select: none;
    }

    /* Mobile-first: long ASCII lines can force horizontal overflow. */
    .gb-ascii-divider {
      display: none;
    }
    @media (min-width: 640px) {
      .gb-ascii-divider {
        display: block;
        overflow: hidden;
        white-space: nowrap;
      }
    }
    .gb-name {
      font-weight: 700;
    }
    .gb-link {
      text-decoration: underline;
      text-underline-offset: var(--zag-offset);
    }
    .gb-message {
      white-space: pre-wrap;
    }
    .gb-banner {
      border: var(--zag-stroke) solid;
      border-color: var(--color-zag-accent-dark);
      background: color-mix(
        in oklab,
        var(--color-zag-accent-dark) 10%,
        transparent
      );
    }
    :where(.dark, .dark *) .gb-banner {
      border-color: var(--color-zag-accent-light);
      background: color-mix(
        in oklab,
        var(--color-zag-accent-light) 12%,
        transparent
      );
    }

    .gb-banner-error {
      border-color: var(--color-zag-dark-muted);
      background: color-mix(
        in oklab,
        var(--color-zag-dark-muted) 10%,
        transparent
      );
    }
    :where(.dark, .dark *) .gb-banner-error {
      border-color: var(--color-zag-light-muted);
      background: color-mix(
        in oklab,
        var(--color-zag-light-muted) 12%,
        transparent
      );
    }
    .gb-hp {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
  </style>
</Layout>
