---
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";
import ThemeToggle from "./ThemeToggle.astro";

const { data: config } = await getConfigurationCollection();
---

<header class="zag-bg zag-border-b sticky top-0 w-full z-10">
  <div
    class="zag-bg sm:hidden relative z-50 px-4 py-4 flex items-center justify-between w-full"
  >
    <button class="flex items-center" type="button" aria-label="Toggle navigation menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 512 512"
        class="zag-fill"
      >
        <title>Navigation menu</title>
        <path d="M80 96h352v32H80zm0 144h352v32H80zm0 144h352v32H80z"></path>
      </svg>
    </button>
    <div class="flex items-center gap-4">
      <Anchor url="/guestbook" aria-label="Sign the guestbook" class="flex items-center">
        <span class="gb-icon inline-block" aria-hidden="true" />
      </Anchor>
      <span class="flex items-center">
        <ThemeToggle />
      </span>
    </div>
  </div>
  <nav
    class="zag-bg zag-border-b fixed sm:relative inset-x-0 top-0 h-auto sm:px-4 flex justify-between flex-col gap-8 py-4 text-xl sm:flex-row max-w-2xl mx-auto sm:pt-4 sm:border-none"
  >
    <div
      class="flex flex-col font-mono font-medium gap-4 sm:flex-row px-4 sm:px-0 mt-16 sm:mt-0"
    >
      {
        Object.entries(config.menu).map((i) => (
          <Anchor url={i[1]}>{i[0]}</Anchor>
        ))
      }
    </div>
    <div class="flex items-center gap-4 justify-between px-4 sm:px-0" title="guestbook">
      {
        (
          <Anchor url="/guestbook" aria-label="Sign the guestbook" class="hidden sm:inline-flex sm:items-center">
            <span class="gb-icon inline-block" aria-hidden="true" />
          </Anchor>
        )
      }
      {
        config.personal.githubProfile && (
          <Anchor
            url={config.personal.githubProfile}
            aria-label={`${config.personal.name} GitHub Profile`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              class="zag-fill"
            >
              <title>GitHub</title>
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
            </svg>
          </Anchor>
        )
      }
      <div class="hidden sm:block">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  (() => {
    function triggerEffect(icon) {
      icon.classList.remove("glowing", "wiggling");
      void icon.offsetWidth;
      icon.classList.add("glowing", "wiggling");
      setTimeout(() => icon.classList.remove("glowing", "wiggling"), 2000);
    }

    function initHeaderIcons() {
      const icons = document.querySelectorAll(".gb-icon");
      if (icons.length === 0) return;

      if (window.__headerGuestbookIconTimer) {
        clearTimeout(window.__headerGuestbookIconTimer);
      }

      function scheduleNext() {
        const delay = Math.random() * 15000;
        window.__headerGuestbookIconTimer = setTimeout(() => {
          icons.forEach(triggerEffect);
          scheduleNext();
        }, delay);
      }

      icons.forEach(triggerEffect);
      scheduleNext();
    }

    initHeaderIcons();
    document.addEventListener("astro:page-load", initHeaderIcons);
  })();
</script>

<script is:inline>
  (() => {
    function initHeaderNav() {
      const header = document.querySelector("header");
      const button = header?.querySelector('button[aria-label="Toggle navigation menu"]');
      const nav = header?.querySelector("nav");
      if (!button || !nav) return;

      let isOpen = false;

      function updateNavState() {
        const isMobile = window.matchMedia("(max-width: 640px)").matches;
        if (isMobile) {
          nav.style.transform = isOpen ? "translateY(0)" : "translateY(-100%)";
        } else {
          nav.style.transform = "translateY(0)";
          isOpen = false;
        }
      }

      if (button.dataset.navBound === "true") {
        updateNavState();
        return;
      }

      function toggleNav() {
        isOpen = !isOpen;
        updateNavState();
      }

      button.dataset.navBound = "true";
      button.addEventListener("click", toggleNav);

      if (!window.__headerResizeBound) {
        window.__headerResizeBound = true;
        window.addEventListener("resize", () => {
          document
            .querySelectorAll("header nav")
            .forEach((currentNav) => {
              const isMobile = window.matchMedia("(max-width: 640px)").matches;
              currentNav.style.transform = isMobile ? "translateY(-100%)" : "translateY(0)";
            });
        });
      }

      updateNavState();
    }

    initHeaderNav();
    document.addEventListener("astro:page-load", initHeaderNav);
  })();
</script>

<style>
  .gb-icon {
    width: 32px;
    height: 32px;
    background-image: url("/guestbook.png");
    background-repeat: no-repeat;
    background-size: 32px 32px;
    background-position: 0 0;
    image-rendering: pixelated;
    position: relative;
    overflow: visible;
    box-shadow: 0 0 4px 1px rgba(239, 68, 68, 0.4);
  }

  @keyframes glow-pulse {
    0%,
    100% {
      box-shadow: 0 0 4px 1px rgba(239, 68, 68, 0.4);
    }
    50% {
      box-shadow: 0 0 20px 6px rgba(239, 68, 68, 0.9), 0 0 40px 10px rgba(239, 68, 68, 0.5);
    }
  }

  .gb-icon.glowing {
    animation: glow-pulse 2s ease-in-out;
  }

  @keyframes wiggle {
    0%,
    100% {
      transform: rotate(0deg);
    }
    25% {
      transform: rotate(-5deg);
    }
    75% {
      transform: rotate(5deg);
    }
  }

  .gb-icon.wiggling {
    animation: wiggle 0.3s ease-in-out;
  }

  @media (min-width: 640px) {
    .gb-icon {
      width: 40px;
      height: 40px;
      background-size: 40px 40px;
    }
  }
</style>
