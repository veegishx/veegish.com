---
---

<span id="counter-value">0</span>
<button id="counter-increment">Increment</button>

<script is:inline>
  (() => {
    function initCounter() {
      const counterValue = document.getElementById("counter-value");
      const counterIncrement = document.getElementById("counter-increment");

      if (!counterValue || !counterIncrement) return;
      if (counterIncrement.dataset.counterBound === "true") return;

      let count = 0;
      counterIncrement.dataset.counterBound = "true";
      counterIncrement.addEventListener("click", () => {
        count += 1;
        counterValue.textContent = count.toString();
      });
    }

    initCounter();

    // Use multiple event types for robustness
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCounter);
    } else {
      initCounter();
    }
  })();
</script>
