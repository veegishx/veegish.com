---
import { getConfigurationCollection } from "../../lib/utils";

const { data: config } = await getConfigurationCollection();
---

<div class="flex flex-col items-center sm:flex-row gap-8">
  <img
    src={config.hero.image}
    alt={`${config.hero.title} Profile Image`}
    class="rounded-full max-w-40 w-40 h-40 mb-4 z-0 grayscale"
  />
  <div class="relative">
    <h1
      class="text-3xl sm:text-4xl font-display font-semibold opsz text-center sm:text-left hero-wave-title"
      data-text={config.hero.title}
    >
      {config.hero.title}
    </h1>
    <div
      class="chatbubble-wrapper absolute left-[calc(100%-8rem)] sm:left-[calc(100%-12rem)] -top-60 sm:-top-16 w-32 h-32"
    >
      <img
        src="/chatbubble.png"
        alt="Chat bubble"
        class="w-full h-full object-contain"
      />
      <span
        class="chatbubble-text absolute -mt-2 inset-0 flex items-center justify-center text-xs font-display text-zag-dark"
      ></span>
    </div>
    <h2
      class="text-center text-xl sm:text-2xl font-mono font-medium sm:text-left"
    >
      <p set:html={config.hero.subtitle} />
    </h2>
    <p
      class="mt-4 text-center text-sm text-zag-dark-muted font-mono font-medium sm:text-left"
      set:html={config.hero.extraText}
    />
  </div>
</div>

<style>
  .hero-wave-title {
    position: relative;
    transition: text-shadow 0.5s ease;
  }

  .hero-wave-title::after {
    content: attr(data-text);
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      #ff0000 0%,
      #ff7700 15%,
      #ffdd00 30%,
      #00dd00 45%,
      #0088ff 60%,
      #7700ff 75%,
      #ff0000 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: wave-fill 3s linear infinite;
    text-shadow:
      1px 1px 0 rgba(0, 0, 0, 0.2),
      2px 2px 0 rgba(0, 0, 0, 0.15),
      3px 3px 0 rgba(0, 0, 0, 0.1),
      4px 4px 2px rgba(0, 0, 0, 0.05);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .hero-wave-title:hover {
    text-shadow:
      1px 1px 0 rgba(0, 0, 0, 0.2),
      2px 2px 0 rgba(0, 0, 0, 0.15),
      3px 3px 0 rgba(0, 0, 0, 0.1),
      4px 4px 2px rgba(0, 0, 0, 0.05);
  }

  .hero-wave-title:hover::after {
    opacity: 1;
  }

  @keyframes wave-fill {
    0% {
      background-position: 0% center;
    }
    100% {
      background-position: 200% center;
    }
  }

  :where(.dark, .dark *) .hero-wave-title::after {
    text-shadow:
      1px 1px 0 rgba(255, 255, 255, 0.15),
      2px 2px 0 rgba(255, 255, 255, 0.1),
      3px 3px 0 rgba(255, 255, 255, 0.05),
      4px 4px 2px rgba(255, 255, 255, 0.025);
  }

  :where(.dark, .dark *) .hero-wave-title:hover {
    text-shadow:
      1px 1px 0 rgba(255, 255, 255, 0.15),
      2px 2px 0 rgba(255, 255, 255, 0.1),
      3px 3px 0 rgba(255, 255, 255, 0.05),
      4px 4px 2px rgba(255, 255, 255, 0.025);
  }

  .chatbubble-wrapper {
    filter: drop-shadow(2px 4px 6px rgba(0, 0, 0, 0.3));
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  :where(.dark, .dark *) .chatbubble-wrapper {
    filter: drop-shadow(2px 4px 6px rgba(255, 255, 255, 0.15));
  }

  .chatbubble-text {
    transition: opacity 0.3s ease;
  }
</style>

<script is:inline>
  (() => {
    const hellos = [
      "Hello",
      "Bonjour",
      "Hola",
      "Hallo",
      "Ciao",
      "こんにちは",
      "안녕하세요",
      "你好",
      "Привет",
    ];
    let index = 0;
    let interval;

    function initChatBubble() {
      const textEl = document.querySelector(".chatbubble-text");
      if (!textEl) return;

      function next() {
        textEl.style.opacity = "0";
        setTimeout(() => {
          textEl.textContent = hellos[index];
          textEl.style.opacity = "1";
          index = (index + 1) % hellos.length;
        }, 300);
      }

      next();
      interval = setInterval(next, 2000);
    }

    initChatBubble();
    document.addEventListener("astro:page-load", () => {
      clearInterval(interval);
      initChatBubble();
    });
  })();
</script>
